{
  "name": "neurobalance-ai",
  "version": "1.0.0",
  "private": true,
  "description": "NeuroBalance AI — Optimized Monorepo",
  "scripts": {
    "dev:api": "npm run dev --workspace=@neurobalance/api",
    "dev:web": "npm run dev --workspace=@neurobalance/web",
    "dev:ai": "cd services/ai && uvicorn src.main:app --reload --port 8000",
    "install:all": "npm install",
    "docker:up": "docker-compose up --build",
    "docker:down": "docker-compose down",
    "clean": "Remove-Item -Recurse -Force **/node_modules, **/dist, **/.next, **/tsconfig.tsbuildinfo -ErrorAction SilentlyContinue"
  },
  "workspaces": [
    "apps/web",
    "apps/api",
    "packages/*"
  ]
}
